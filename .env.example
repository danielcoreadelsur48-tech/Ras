# ============================================================
# RAS STORE — Variables de entorno
# Copia este archivo como .env y completa los valores reales
# NUNCA subas .env a git
# ============================================================

# Base de datos (SQLite para desarrollo local)
DATABASE_URL="file:./dev.db"

# Auth — genera el secret con: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Stripe (https://dashboard.stripe.com/apikeys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_SECRET_KEY=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# PayPal (https://developer.paypal.com/dashboard/applications)
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Email SMTP (Gmail: habilita "Contraseñas de aplicación" en tu cuenta)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Ras Store <noreply@rasstore007.com>
